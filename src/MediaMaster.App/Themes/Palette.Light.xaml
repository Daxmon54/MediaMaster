<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light palette. Only brushes live here; ThemeManager swaps this whole dictionary at runtime.
         All the styles/templates in Controls.xaml reference these keys via DynamicResource, so a
         swap updates every open window live. -->
    <SolidColorBrush x:Key="Theme.WindowBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.Foreground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="Theme.ControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.ControlBorder" Color="#ABADB3" />
    <SolidColorBrush x:Key="Theme.MenuBarBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="Theme.MenuPopupBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Theme.HoverBackground" Color="#D6E8FF" />
    <SolidColorBrush x:Key="Theme.SelectionBackground" Color="#CCE8FF" />
    <SolidColorBrush x:Key="Theme.SelectionForeground" Color="#000000" />
    <SolidColorBrush x:Key="Theme.DisabledForeground" Color="#9A9A9A" />
    <SolidColorBrush x:Key="Theme.Accent" Color="#2D8A0E" />

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light theme palette -->
    <SolidColorBrush x:Key="AppWindowBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AppControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppControlBorder" Color="#ABADB3" />
    <SolidColorBrush x:Key="AppMenuBackground" Color="#F5F5F5" />
    <SolidColorBrush x:Key="AppSelectionBackground" Color="#CCE8FF" />
    <SolidColorBrush x:Key="AppSelectionForeground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AppReadOnlyBackground" Color="#EEEEEE" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppWindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
        <Setter Property="CaretBrush" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
        <Setter Property="CaretBrush" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AppSelectionBackground}" />
                <Setter Property="Foreground" Value="{StaticResource AppSelectionForeground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Menu bar and native combo dropdowns are left with default chrome (see Dark.xaml note). -->

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource AppWindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AppMenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

</ResourceDictionary>

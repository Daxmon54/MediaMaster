<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme palette -->
    <SolidColorBrush x:Key="AppWindowBackground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="AppForeground" Color="#F0F0F0" />
    <SolidColorBrush x:Key="AppControlBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="AppControlBorder" Color="#3F3F46" />
    <SolidColorBrush x:Key="AppMenuBackground" Color="#2D2D30" />
    <SolidColorBrush x:Key="AppSelectionBackground" Color="#094771" />
    <SolidColorBrush x:Key="AppSelectionForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AppReadOnlyBackground" Color="#252526" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppWindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
        <Setter Property="CaretBrush" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
        <Setter Property="CaretBrush" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource AppControlBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AppSelectionBackground}" />
                <Setter Property="Foreground" Value="{StaticResource AppSelectionForeground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- The top menu bar and native combo dropdowns are intentionally left with their default
         (light) chrome: fully theming WPF's Menu/MenuItem/ComboBox requires custom control
         templates, and a partial restyle leaves their text unreadable. Keeping them default
         guarantees readability; the client area below is themed. -->

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource AppWindowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AppMenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppControlBorder}" />
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource AppForeground}" />
    </Style>

</ResourceDictionary>

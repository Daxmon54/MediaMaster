<Window x:Class="Views.DestinationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MediaMaster Destination" Height="220" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Theme.WindowBackground}" Foreground="{DynamicResource Theme.Foreground}">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="90" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}" />
            <Button Content="Cancel" Width="90" IsCancel="True" Command="{Binding CancelCommand}" />
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Destination folder" Margin="0,4,0,2" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding FolderPath}" />
                <Button Grid.Column="1" Content="Browse..." Width="80" Margin="6,0,0,0" Click="OnBrowseFolder" />
            </Grid>

            <TextBlock Text="Extended-info export filename" Margin="0,14,0,2" />
            <TextBox Text="{Binding ExtendedFileName}" />
        </StackPanel>
    </DockPanel>
</Window>
